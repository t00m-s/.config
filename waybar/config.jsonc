{
    "layer": "top", // Waybar at top layer
    "position": "top", // Waybar position (top|bottom|left|right)
    // Choose the order of the modules
    "modules-left": [
        "hyprland/workspaces",
        "hyprland/window",
        "custom/spotify"
    ],
    "modules-center": [
        "clock",
        "keyboard-state"
    ],
    "modules-right": [
        "network",
        "tray",
        "pulseaudio",
        "cpu",
        "temperature",
        "backlight",
        "battery",
        "custom/power"
    ],
    // Modules configuration
    "custom/spotify": {
        "exec": "/usr/bin/python3 /home/tom/.config/waybar/scripts/mediaplayer.py --player spotify",
        "format": "{} \uf1bc",
        "return-type": "json",
        "on-click": "playerctl play-pause"
    },
    "hyprland/workspaces": {
        "on-scroll-up": "hyprctl dispatch workspace e+1",
        "on-scroll-down": "hyprctl dispatch workspace e-1"
    },
    "keyboard-state": {
        "numlock": true,
        "capslock": true,
        "format": {
            "numlock": " N {icon}",
            "capslock": "C {icon}"
        },
        "format-icons": {
            "locked": "\uf023",
            "unlocked": "\uf09c"
        }
    },
    "hyprland/window": {
        "max-length": 100,
        "separate-outputs": true
    },
    "clock": {
        "format": "{:%Y-%m-%d %H:%M}"
    },
    "cpu": {
        "format": "{avg_frequency} GHz \uf4bc",
        "on-click": "cpupower-gui",
    },
    "temperature": {
        "critical-threshold": 85,
        "format": "{temperatureC}┬░C"
    },
    "backlight": {
        "format": "{percent}% {icon}",
        "format-icons": [
            "юОН",
            "юПУ",
            "юПС",
            "юПП",
            "юПО",
            "юПН",
            "юПК",
            "юПИ",
            "юОЫ"
        ]
    },
    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% \udb80\udc84",
        "format-plugged": "{capacity}% \uf1e6",
        "format-alt": "{time} {icon}",
        "format-icons": [
            "яЙД",
            "яЙГ",
            "яЙВ",
            "яЙБ",
            "яЙА"
        ]
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "яАж Muted",
        "scroll-step": 1,
        "on-click": "pavucontrol",
        "format-icons": {
            "headphone": "яАе",
            "headset": "яАе",
            "default": [
                "яАж",
                "яАз",
                "яАи"
            ]
        }
    },
    "custom/power": {
        "format": "тП╗",
        "on-click": "wlogout",
        "tooltip": false
    },
    "network": {
        "format": "{bandwidthDownBytes} \uf409 {bandwidthUpBytes} \uf40a",
        "interval": 1,
        "tooltip": false
    },
}
